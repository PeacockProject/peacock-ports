--- a/hw/xfree86/fbdevhw/fbdevhw.c
+++ b/hw/xfree86/fbdevhw/fbdevhw.c
@@ -335,8 +335,12 @@
         char *sysfs_path = NULL;
         char *node = strrchr(dev, '/') + 1;
 
-        if (asprintf(&sysfs_path, "/sys/class/graphics/%s/device/subsystem", node) < 0 ||
-            readlink(sysfs_path, buf, sizeof(buf) - 1) < 0 ||
+        if (asprintf(&sysfs_path, "/sys/class/graphics/%s/device/subsystem", node) < 0) {
+            close(fd);
+            return -1;
+        }
+
+        if (readlink(sysfs_path, buf, sizeof(buf) - 1) >= 0 &&
             strstr(buf, "bus/pci")) {
             free(sysfs_path);
             close(fd);
@@ -482,6 +486,25 @@
     xfree2fbdev_fblayout(pScrn, &req_var);
     xfree2fbdev_timing(mode, &req_var);
 
+    /*
+     * Samsung jflte quirk:
+     * The msm fbdev stack reports RGBA8888-style channel offsets
+     * (r=24,g=16,b=8,a=0) while Xorg runs depth 24 / bpp 32.
+     * Render cannot match that default visual and GTK apps can fail with
+     * RenderBadPicture. Request canonical XRGB8888 channel placement so
+     * fbdevhw returns a Render-compatible visual mask set.
+     */
+    if (pScrn->depth == 24 && req_var.bits_per_pixel == 32 &&
+        req_var.red.length == 8 && req_var.green.length == 8 &&
+        req_var.blue.length == 8 && req_var.transp.length == 8 &&
+        req_var.red.offset == 24 && req_var.green.offset == 16 &&
+        req_var.blue.offset == 8 && req_var.transp.offset == 0) {
+        req_var.red.offset = 16;
+        req_var.green.offset = 8;
+        req_var.blue.offset = 0;
+        req_var.transp.offset = 24;
+    }
+
 #ifdef DEBUG
     print_xfree_mode("init", mode);
     print_fbdev_mode("init", &req_var);
